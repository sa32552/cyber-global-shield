            "cwd": "${workspaceFolder}\\Cyber Global Shield"
        },
        {
            "name": "📊 Dashboard Web (Live Server)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "live-server",
                "${workspaceFolder}\\Cyber Global Shield\\apps\\web",
                "--port=5500",
                "--open=index.html"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "📈 Dashboard Transcendent (Live Server)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "live-server",
                "${workspaceFolder}\\Cyber Global Shield\\apps\\web",
                "--port=5501",
                "--open=transcendent_dashboard.html"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "🔬 Tests unitaires",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${workspaceFolder}\\Cyber Global Shield\\tests\\",
                "-v"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}\\Cyber Global Shield"

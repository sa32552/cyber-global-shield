{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Cyber Global Shield - Lancer la plateforme",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}\\Cyber Global Shield\\app.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}\\Cyber Global Shield",
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\Cyber Global Shield"
            }
        },
        {
            "name": "🧪 Security Orchestrator - Test",
            "type": "python",
            "request": "launch",

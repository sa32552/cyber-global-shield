# ============================================================
# Cyber Global Shield v2.0 — Configuration Example
# Copy to .env and fill with your credentials
# ============================================================
# ⚠️  SECURITY WARNING ⚠️
# Never commit the .env file to version control!
# In production, use a secrets manager:
#   - HashiCorp Vault (set SECRETS_BACKEND=vault)
#   - AWS Secrets Manager (set SECRETS_BACKEND=aws)
#   - Azure Key Vault (set SECRETS_BACKEND=azure)
# ============================================================

# Core
APP_NAME=Cyber Global Shield
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=development          # development, staging, or production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security (REQUIRED - generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-at-least-32-chars-long-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin credentials (REQUIRED in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-at-least-12-chars

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LOGS=raw_logs
KAFKA_TOPIC_ALERTS=alerts

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=cyber_shield

# Ray
RAY_ADDRESS=auto
RAY_NUM_CPUS=4
RAY_NUM_GPUS=0

# Federated Learning
FLOWER_SERVER_ADDRESS=0.0.0.0:8080
FLOWER_NUM_ROUNDS=10
FLOWER_MIN_CLIENTS=2

# LLM / AI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
LLM_PROVIDER=openai
CREWAI_MODEL=gpt-4-turbo
CREWAI_TEMPERATURE=0.1

# Threat Intelligence
MISP_URL=https://misp.your-org.com
MISP_API_KEY=your-misp-api-key
MISP_VERIFY_SSL=true              # ⚠️ Keep true in production!

CORTEX_URL=https://cortex.your-org.com
CORTEX_API_KEY=your-cortex-api-key

# SOAR - Firewall (FortiGate / Palo Alto)
FIREWALL_URL=https://your-firewall.local
FIREWALL_API_KEY=your-firewall-api-token

# SOAR - EDR (CrowdStrike Falcon / SentinelOne)
EDR_URL=https://api.crowdstrike.com
EDR_API_KEY=your-edr-api-key
EDR_API_SECRET=your-edr-api-secret

# SOAR - IAM (Azure AD / Entra ID / Okta)
IAM_URL=https://graph.microsoft.com/v1.0
IAM_API_KEY=your-azure-ad-bearer-token

# SOAR - DNS (Pi-hole)
DNS_URL=http://pi-hole.local
DNS_API_KEY=your-pihole-api-token

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/...

# Ticketing
JIRA_URL=https://your-org.atlassian.net
JIRA_TOKEN=your-jira-api-token

# Observability
PROMETHEUS_PORT=9090
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4318

# Rate Limiting
RATE_LIMIT_PER_SECOND=10000
RATE_LIMIT_BURST=50000

# Alerting Thresholds
ANOMALY_THRESHOLD=0.95
THREAT_SCORE_THRESHOLD=0.7
MAX_ALERTS_PER_SECOND=1000

# Secrets Manager Configuration
# Options: env (default), vault, aws, azure
SECRETS_BACKEND=env
# VAULT_ADDR=https://vault.your-org.com:8200
# VAULT_TOKEN=hvs.your-vault-token
# AWS_REGION=us-east-1

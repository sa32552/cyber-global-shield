# ============================================================
# Cyber Global Shield v2.0 — Configuration Example
# Copy to .env and fill with your credentials
# ============================================================

# Core
APP_NAME=Cyber Global Shield
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security (CHANGE THESE in production!)
SECRET_KEY=your-super-secret-key-change-me-now
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LOGS=raw_logs
KAFKA_TOPIC_ALERTS=alerts

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=cyber_shield

# Ray
RAY_ADDRESS=auto
RAY_NUM_CPUS=4
RAY_NUM_GPUS=0

# Federated Learning
FLOWER_SERVER_ADDRESS=0.0.0.0:8080
FLOWER_NUM_ROUNDS=10
FLOWER_MIN_CLIENTS=2

# LLM / AI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
LLM_PROVIDER=openai
CREWAI_MODEL=gpt-4-turbo
CREWAI_TEMPERATURE=0.1

# Threat Intelligence
MISP_URL=https://misp.your-org.com
MISP_API_KEY=your-misp-api-key
MISP_VERIFY_SSL=false

CORTEX_URL=https://cortex.your-org.com
CORTEX_API_KEY=your-cortex-api-key

# SOAR - Firewall (FortiGate / Palo Alto)
# Leave empty to use local iptables fallback
FIREWALL_URL=https://your-firewall.local
FIREWALL_API_KEY=your-firewall-api-token

# SOAR - EDR (CrowdStrike Falcon / SentinelOne)
EDR_URL=https://api.crowdstrike.com
EDR_API_KEY=your-edr-api-key
EDR_API_SECRET=your-edr-api-secret

# SOAR - IAM (Azure AD / Entra ID / Okta)
IAM_URL=https://graph.microsoft.com/v1.0
IAM_API_KEY=your-azure-ad-bearer-token

# SOAR - DNS (Pi-hole / Unbound)
DNS_URL=http://pi-hole.local/admin/api.php
DNS_API_KEY=your-pihole-api-key

# SOAR - Notifications (Slack / Teams)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhook

# SOAR - Ticketing (Jira)
JIRA_URL=https://your-org.atlassian.net
JIRA_TOKEN=your-jira-api-token

# Observability
PROMETHEUS_PORT=9090
OTEL_EXPORTER_ENDPOINT=

# Rate Limiting
RATE_LIMIT_PER_SECOND=10000
RATE_LIMIT_BURST=50000

# Detection Thresholds
ANOMALY_THRESHOLD=0.95
THREAT_SCORE_THRESHOLD=0.7

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_ORG_ID=root
ADMIN_ROLE=admin

# AlienVault OTX (Free Threat Intelligence)
ALIENVAULT_API_KEY=your-alienvault-otx-api-key

# MISP (Additional config)
MISP_VERIFY_SSL=false

# Quantum ML
QUANTUM_N_QUBITS=4
QUANTUM_SHOTS=1024
QUANTUM_BACKEND=qasm_simulator
